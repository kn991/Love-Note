# ── lovenote backend environment ──────────────────────────────────────────
# Copy to `.env` and fill in real values. NEVER commit `.env`.

# Which config class to load: development | testing | production
FLASK_CONFIG=development

# ── Secrets (production refuses to boot if these are empty) ─────────────────
# Generate strong values, e.g.:  python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=
JWT_SECRET=
# Salt for pseudonymous ip/user-agent hashing (sha256(salt:value)).
HASH_SALT=

# ── Database ────────────────────────────────────────────────────────────────
# SQLAlchemy URL. Use the psycopg2 driver.
DATABASE_URL=postgresql+psycopg2://lovenote:lovenote@localhost:5432/lovenote
# Optional separate DB for the test suite.
TEST_DATABASE_URL=postgresql+psycopg2://lovenote:lovenote@localhost:5432/lovenote_test

# ── CORS ──────────────────────────────────────────────────────────────────
# Comma-separated allowlist of frontend origins. Never use "*" with credentials.
CORS_ORIGINS=http://localhost:3000

# ── Cookies ─────────────────────────────────────────────────────────────────
# Set true in production (HTTPS). SameSite: Lax (default) | Strict | None.
COOKIE_SECURE=false
COOKIE_SAMESITE=Lax
# COOKIE_DOMAIN=.example.com

# ── Rate limiting ─────────────────────────────────────────────────────────
# In-memory is fine for single-process dev. Production MUST use Redis.
REDIS_URL=memory://
# REDIS_URL=redis://localhost:6379/0

# ── Misc ────────────────────────────────────────────────────────────────────
# Public base URL of the frontend, used to build invite links.
APP_PUBLIC_URL=http://localhost:3000
# Number of trusted proxy hops (set to 1 when behind nginx). 0 = trust none.
PROXY_FIX_HOPS=0
