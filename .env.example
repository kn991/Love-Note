# ── lovenote · Docker Compose environment ─────────────────────────────────
# Copy to `.env` (same directory as docker-compose.yml), fill in the secrets,
# then run:  docker compose up --build
# NEVER commit `.env`.

# ── Postgres ────────────────────────────────────────────────────────────────
# Used by the `db` service and woven into DATABASE_URL for the backend.
POSTGRES_USER=lovenote
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=lovenote

# ── Backend secrets (REQUIRED — compose refuses to start if empty) ──────────
# Generate each one separately:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=
JWT_SECRET=
# Salt for pseudonymous ip / user-agent hashing (sha256(salt:value)).
HASH_SALT=

# ── CORS / URLs ─────────────────────────────────────────────────────────────
# Comma-separated allowlist of frontend origins. Never "*" with credentials.
CORS_ORIGINS=http://localhost:3000
# Public base URL of the frontend (used to build invite links).
APP_PUBLIC_URL=http://localhost:3000

# ── Cookies ─────────────────────────────────────────────────────────────────
# Set COOKIE_SECURE=true once you serve over HTTPS.
# SameSite: Lax (default) | Strict | None.
COOKIE_SECURE=false
COOKIE_SAMESITE=Lax

# ── Proxy ───────────────────────────────────────────────────────────────────
# Trusted proxy hops. 0 = trust none. Set to 1 when behind a single reverse proxy.
PROXY_FIX_HOPS=0

# ── Frontend (build-time, inlined into the browser bundle) ──────────────────
# Must be the API URL the BROWSER will call, INCLUDING the /api suffix.
NEXT_PUBLIC_API_BASE_URL=http://localhost:5000/api
